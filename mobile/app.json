{
  "expo": {
    "name": "HealthMap AI",
    "slug": "healthmap-ai",
    "scheme": "healthmapai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "primaryColor": "#2c73d9",
    "backgroundColor": "#f4f8fc",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f4f8fc"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2c73d9",
          "defaultChannel": "reminders"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.healthmapai.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock your health records.",
        "NSCameraUsageDescription": "Capture photos of medical reports and prescriptions.",
        "NSPhotoLibraryUsageDescription": "Attach photos of reports from your library.",
        "NSUserNotificationsUsageDescription": "Send appointment and medication reminders.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.healthmapai.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2c73d9"
      },
      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "READ_EXTERNAL_STORAGE",
        "CAMERA"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "http://localhost:3001/api",
      "eas": {
        "projectId": ""
      }
    }
  }
}
